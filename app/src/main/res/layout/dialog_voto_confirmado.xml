<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_card"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp">

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_check_circle"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvDialogTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="voto confirmado!"
        android:textColor="@color/gold"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvDialogMensagem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="seus votos foram registrados com sucesso"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnDialogOk"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_button_gold"
        android:text="ok"
        android:textColor="@color/bg_dark"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="15sp"
        android:stateListAnimator="@null" />

</LinearLayout>
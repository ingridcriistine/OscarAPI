<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="40dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="confirmar voto"
        android:textColor="@color/text_muted"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:gravity="center"
        android:layout_marginBottom="14dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_centerVertical="true"
            android:background="@color/divider_line" />

        <TextView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_centerInParent="true"
            android:background="@color/gold"
            android:rotation="45" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="filme"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvFilme"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textColor="@color/text_light"
            android:textStyle="bold"
            android:textSize="14sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_line" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="diretor"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDiretor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textColor="@color/text_light"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColorLink="@color/gold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="32dp"
        android:background="@color/divider_line" />

    <EditText
        android:id="@+id/etToken"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input_field"
        android:hint="token de votação"
        android:inputType="number"
        android:paddingHorizontal="16dp"
        android:textColor="@color/text_light"
        android:textColorHint="@color/text_muted"
        android:textSize="14sp"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnConfirmar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_button_gold"
        android:text="confirmar voto"
        android:textColor="@color/bg_dark"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="15sp"
        android:stateListAnimator="@null" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Usando MaterialComponents (que descende de AppCompat) para aceitar os novos atributos de cores -->
    <style name="Theme.OscarAPI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Cores Principais -->
        <item name="colorPrimary">@color/bg_dark</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Cores Secundárias -->
        <item name="colorSecondary">@color/gold</item>
        <item name="colorSecondaryVariant">@color/gold_light</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
